# Никогда не коммитим секреты — только README с описанием схемы
# Исключение: test-credentials.json — тестовые ключи в приватном репо, переживают сессии
claude-vault/secrets/*
!claude-vault/secrets/README.md
!claude-vault/secrets/.gitkeep
!claude-vault/secrets/test-credentials.json

# Окружение
.env
.env.*
!.env.example

# Системное
.DS_Store
Thumbs.db

# Node / Python кэши, если появятся
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Промежуточные данные песочниц/выгрузок
/tmp/
*.log
